# ──────────────────────────────────────────────────────────
# OCR Admin UI — 환경 변수 예시
# 복사: cp .env.example .env.local
# .env.local 은 .gitignore 에 포함되어 있어 커밋되지 않습니다.
# ──────────────────────────────────────────────────────────

# Keycloak 클라이언트 설정
# 개발: ocr-backoffice (realm-ocr.json 에 정의됨)
# redirectUri 에 http://localhost:3000/api/auth/callback/keycloak 를 추가해야 함
# (infra/manifests/keycloak/realm-ocr.json 수정 + Keycloak 재적용)
KEYCLOAK_CLIENT_ID=ocr-backoffice
KEYCLOAK_CLIENT_SECRET=__BACKOFFICE_CLIENT_SECRET__

# Keycloak issuer URL
# 개발: kubectl -n admin port-forward svc/keycloak 8443:443 후 사용
KEYCLOAK_ISSUER=https://localhost:8443/realms/ocr

# NextAuth 시크릿 — 운영에서 반드시 변경
# 생성: openssl rand -base64 32
AUTH_SECRET=changeme-generate-with-openssl-rand-base64-32

# NextAuth 기본 URL
NEXTAUTH_URL=http://localhost:3000

# ⚠️ 개발 전용: ocr-internal 자체서명 CA 검증 비활성화
# 운영(B3-T4)에서는 제거하고 NODE_EXTRA_CA_CERTS 로 CA 마운트
NODE_TLS_REJECT_UNAUTHORIZED=0

# upload-api 엔드포인트 (NEXT_PUBLIC_ → 브라우저에서도 접근 가능)
# 개발: kubectl -n dmz port-forward svc/upload-api 18080:80
# 운영(B3-T4): 클러스터 내부 ClusterIP 주소로 변경
NEXT_PUBLIC_UPLOAD_API_BASE=http://localhost:18080
